{
    "manifest_version": 3,
    "name": "TDTU Two-in-One Optimizer",
    "version": "1.2",
    "description": "Auto login and prevent auto logout for TDTU Portal & Elearning.",
    "permissions": [
        "storage"
    ],
    "host_permissions": [
        "*://old-stdportal.tdtu.edu.vn/*",
        "*://elearning.tdtu.edu.vn/*"
    ],
    "icons": {
        "16": "icon.png",
        "32": "icon.png",
        "48": "icon.png",
        "128": "icon.png"
    },
    "action": {
        "default_popup": "popup.html",
        "default_title": "TDTU Settings",
        "default_icon": "icon.png"
    },
    "content_scripts": [
        {
            "matches": [
                "*://old-stdportal.tdtu.edu.vn/*",
                "*://elearning.tdtu.edu.vn/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ]
}